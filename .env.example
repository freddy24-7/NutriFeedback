# =============================================================
# NutriApp — Environment Variables
# Copy to .env.local and fill in all values before running.
# See .claude/gap-analysis.md for setup instructions per key.
# =============================================================

# NEON DATABASE
# Create project: https://neon.tech → EU Frankfurt region
# Create branches: main, dev, staging
DATABASE_URL=                    # dev branch pooled connection (runtime)
DATABASE_URL_UNPOOLED=           # dev branch direct connection (migrations only)
DATABASE_URL_PROD=               # main branch pooled connection (production)

# BETTER AUTH (Neon Auth — self-hosted, sessions stored in your Neon DB)
# No external service needed — generate the secret locally:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=              # random 32-byte hex secret (server only)
BETTER_AUTH_URL=http://localhost:5173  # public site URL (redirects); on Vercel use https://your-domain.com (same as VITE_APP_URL)

# Vercel Production: set VITE_APP_URL and BETTER_AUTH_URL to your live https URL (no trailing slash).
# Vercel sets VERCEL_URL automatically — the API allows it for CORS/trustedOrigins so Preview deploys work.

# AI — DEV (free tier)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=                  # server-side only

# AI — PROD
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=               # server-side only

# UPSTASH REDIS (EU region) — recommended in production for rate limits + barcode cache.
# If unset, the API still starts; rate limits become no-ops and barcode cache is skipped.
# Create DB: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# STRIPE — use TEST keys for dev
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=               # server-side only
STRIPE_WEBHOOK_SECRET=           # from: stripe listen --forward-to localhost:5173/api/stripe/webhook
VITE_STRIPE_PUBLISHABLE_KEY=     # client-safe publishable key
STRIPE_PRICE_ID=price_live_xxx   # live mode — create in Stripe dashboard → Products
STRIPE_PRICE_ID_TEST=price_test_xxx  # test mode — separate price in Stripe test mode

# RESEND
# Create account: https://resend.com → verify domain first
RESEND_API_KEY=
RESEND_FROM_EMAIL=               # e.g. noreply@yourdomain.com

# SECURITY
# Generate: openssl rand -hex 32
IP_HASH_SECRET=                  # GDPR-compliant IP hashing — never store raw IPs

# APP
VITE_APP_URL=http://localhost:5173
NODE_ENV=development

# Local dev only — `npm run dev` starts the API on this port; Vite proxies /api here.
# Override proxy target: DEV_API_PROXY=http://127.0.0.1:9999
DEV_API_PORT=8787
