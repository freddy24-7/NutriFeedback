{
  "name": "nutriapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,green \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:vite": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vite",
    "dev:api": "NODE_ENV=development NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs --require ./scripts/load-env.cjs\" tsx --tsconfig tsconfig.app.json src/api/dev-server.ts",
    "sitemap": "node ./scripts/generate-sitemap.cjs",
    "prebuild": "node ./scripts/generate-sitemap.cjs",
    "build": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" tsc -b && vite build && npm run build:api",
    "build:api": "esbuild src/api/index.ts --bundle --platform=node --format=esm --tsconfig=tsconfig.app.json --outfile=api/index.js",
    "postbuild": "node ./scripts/inject-meta.cjs",
    "preview": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b",
    "format": "prettier --write .",
    "test:unit": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vitest run --config vitest.unit.config.ts",
    "test:integration": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:i18n": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vitest run tests/unit/i18n.test.ts",
    "test": "NODE_OPTIONS=\"--require ./scripts/crypto-polyfill.cjs\" vitest run && playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.1",
    "@clerk/clerk-react": "^5.61.3",
    "@fontsource/dm-mono": "^5.1.0",
    "@fontsource/dm-sans": "^5.1.0",
    "@fontsource/plus-jakarta-sans": "^5.1.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@neondatabase/serverless": "^0.10.0",
    "@tanstack/react-query": "^5.62.0",
    "@upstash/ratelimit": "^2.0.4",
    "@upstash/redis": "^1.34.0",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.21.3",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "dompurify": "^3.2.0",
    "drizzle-orm": "^0.37.0",
    "drizzle-zod": "^0.5.1",
    "fuse.js": "^7.0.0",
    "hono": "^4.6.0",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "resend": "^4.0.0",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.15.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.15.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "node-fetch": "^2.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "undici": "^5.29.0",
    "vite": "^5.4.0",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.8",
    "workbox-window": "^7.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  }
}
